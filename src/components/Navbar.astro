---
// Primary site navigation: fixed desktop bar + full-screen mobile sidebar.
// On the home page anchor links are same-page hashes (#lab); elsewhere they
// point back to the home page (/#lab). The Insights link is a real route and
// appears in both the desktop nav and the mobile sidebar.
interface Props {
  home?: boolean;
}

const { home = false } = Astro.props;
const base = home ? '' : '/';
const links = [
  { href: `${base}#lab`, label: 'Lab' },
  { href: `${base}#glyphon`, label: 'Flagship' },
  { href: `${base}#products`, label: 'Products' },
  { href: `${base}#missions`, label: 'Engagements' },
  { href: `${base}#resume`, label: 'Resume' },
  { href: '/insights/', label: 'Insights' },
  { href: `${base}#connect`, label: 'Connect' },
];
---

<!-- Top Nav -->
<nav class="fixed inset-x-0 top-0 z-40 backdrop-blur-md" aria-label="Primary">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-8">
    <a href={home ? '#top' : '/'} class="font-mono text-sm uppercase tracking-[0.28em] text-text">
      <span class="text-accent" aria-hidden="true">/</span>&nbsp;Dayel Ostraco
    </a>
    <ul class="hidden items-center gap-6 font-mono text-xs uppercase tracking-[0.22em] text-text/80 lg:flex xl:gap-8">
      {links.map((l) => (
        <li><a href={l.href} class="transition-colors hover:text-accent">{l.label}</a></li>
      ))}
    </ul>
    <button type="button" data-sidebar-trigger class="lg:hidden" aria-label="Open menu">
      <svg aria-hidden="true" class="h-6 w-6 fill-text"><use href="/assets/svg/icons.svg#menu"/></svg>
    </button>
  </div>
</nav>

<!-- Mobile Sidebar -->
<nav data-sidebar class="fixed inset-0 z-50 hidden flex-col bg-bg p-8 dot-grid" aria-label="Mobile menu">
  <div class="flex justify-between items-center">
    <span class="font-mono text-sm uppercase tracking-[0.28em] text-accent">menu</span>
    <button type="button" data-sidebar-close aria-label="Close menu">
      <svg aria-hidden="true" class="h-7 w-7 fill-text"><use href="/assets/svg/icons.svg#close"/></svg>
    </button>
  </div>
  <ul class="mt-12 space-y-6 font-mono text-2xl uppercase tracking-[0.18em]">
    {links.map((l) => (
      <li><a href={l.href} class="hover:text-accent">{l.label}</a></li>
    ))}
  </ul>
  <ul class="mt-auto flex gap-6 pt-8">
    <li><a href="mailto:dayel.ostraco@proton.me" aria-label="Email"><svg aria-hidden="true" class="h-7 w-7 fill-text"><use href="/assets/svg/icons.svg#mail"/></svg></a></li>
    <li><a href="https://github.com/dayelostraco" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><svg aria-hidden="true" class="h-7 w-7 fill-text"><use href="/assets/svg/icons.svg#github"/></svg></a></li>
    <li><a href="https://www.linkedin.com/in/dayelostraco" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><svg aria-hidden="true" class="h-7 w-7 fill-text"><use href="/assets/svg/icons.svg#linkedin"/></svg></a></li>
  </ul>
</nav>
