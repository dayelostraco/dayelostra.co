---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights', ({ data }) => import.meta.env.DEV || !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Read-next: every other Insights post, newest first, capped at 2.
// Stays empty (and the section hides) when the collection has only
// the current post; scales naturally as more posts publish.
const allInsights = await getCollection('insights', ({ data }) => import.meta.env.DEV || !data.draft);
const readNext = allInsights
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

// timeZone: 'UTC' — frontmatter dates are date-only (coerced to UTC
// midnight); formatting in UTC shows the intended calendar day instead
// of rolling back a day on west-of-UTC build machines.
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const ogImagePath = post.data.ogImage || `/assets/img/og/og-insights-${post.id}.png`;
const canonicalUrl = new URL(`/insights/${post.id}/`, Astro.site).href;

// BlogPosting schema: the machine-readable author->article link that
// answer engines and the knowledge graph use for attribution.
const author = {
  '@type': 'Person',
  name: 'Dayel Ostraco',
  url: 'https://dayelostra.co/',
  jobTitle: 'Chief Technology Officer',
  sameAs: [
    'https://www.linkedin.com/in/dayelostraco',
    'https://github.com/dayelostraco',
    'https://www.accelerasolutions.com/our-team#dayel-ostraco',
  ],
};
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.summary,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author,
  publisher: author,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  url: canonicalUrl,
  image: new URL(ogImagePath, Astro.site).href,
  ...(post.data.tags && post.data.tags.length > 0 ? { keywords: post.data.tags.join(', ') } : {}),
  inLanguage: 'en-US',
};
---
<Layout
  title={`${post.data.seoTitle ?? post.data.title} · Dayel Ostraco`}
  description={post.data.summary}
  canonical={canonicalUrl}
  ogTitle={post.data.title}
  ogImage={ogImagePath}
  ogImageAlt={post.data.title}
  ogType="article"
  extraJsonLd={blogPosting}
>
  <Navbar home={false} />

  <main id="main-content" tabindex="-1">
    <article class="relative isolate">

      <!-- Dark hero -->
      <header class="section-dark corners corners-lg relative overflow-hidden px-6 pt-32 pb-16 lg:px-8 lg:pt-40 lg:pb-20">
        <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
        <div class="absolute inset-0 -z-10 dot-grid opacity-40" aria-hidden="true"></div>
        <div class="absolute inset-0 -z-10 grain opacity-25" aria-hidden="true"></div>
        <span class="section-watermark-text" aria-hidden="true" style="top:1rem;right:2rem;" data-watermark="/ESSAY"></span>

        <div class="mx-auto max-w-3xl">
          <p class="eyebrow">Insights</p>

          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="mt-7 flex flex-wrap gap-2">
              {post.data.tags.map(tag => (
                <li class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-accent ring-1 ring-accent/25">
                  {tag}
                </li>
              ))}
            </ul>
          )}

          <h1 class="mt-6 text-balance text-3xl font-semibold leading-tight tracking-tight md:text-4xl lg:text-5xl">
            {post.data.title}
          </h1>
          <p class="mt-7 text-balance text-lg leading-relaxed text-text-dim md:text-xl">
            {post.data.summary}
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-5 border-t border-white/10 pt-7">
            <div>
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-accent">By</p>
              <a href="https://www.linkedin.com/in/dayelostraco" target="_blank" rel="noopener noreferrer" class="mt-1 block text-base font-semibold transition-colors hover:text-accent">
                Dayel Ostraco
              </a>
            </div>

            <div class="border-l border-white/10 pl-8">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-accent">Date</p>
              <time datetime={post.data.date.toISOString()} class="mt-1 block font-mono text-sm uppercase tracking-[0.2em] text-text-dim">
                {fmtDate(post.data.date)}
              </time>
              {post.data.readTime && (
                <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim">{post.data.readTime}</p>
              )}
            </div>
          </div>
        </div>
      </header>

      <!-- Hero image straddles the dark/light boundary. Only renders when set. -->
      {post.data.heroImage && (
        <div class="relative">
          <figure class="mx-auto max-w-5xl px-6 lg:px-8">
            <div class="corners -mt-14 overflow-hidden">
              <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
              <Image
                src={post.data.heroImage}
                alt={post.data.heroImageAlt ?? ''}
                widths={[800, 1200, 1600]}
                sizes="(min-width: 1024px) 1024px, 100vw"
                class="h-auto w-full"
                loading="eager"
              />
            </div>
          </figure>
        </div>
      )}

      <!-- Light reading band. Article prose + Read next + back link. -->
      <section aria-label="Article" class:list={['relative overflow-hidden px-6 lg:px-8', post.data.heroImage ? 'pt-16 pb-24 lg:pt-20 lg:pb-32' : 'pt-20 pb-24 lg:pt-24 lg:pb-32']}>
        <span class="section-watermark" aria-hidden="true" style="top:0;left:2rem;" data-watermark={post.data.bodyWatermark ?? '/ESSAY'}></span>

        <div class="relative mx-auto max-w-3xl">
          <div class="corners glass p-7 sm:p-10">
            <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
            <div class="article-prose">
              <Content />
            </div>
          </div>

          {readNext.length > 0 && (
            <section aria-labelledby="read-next-heading" class="mt-16">
              <h2 id="read-next-heading" class="eyebrow">Read next</h2>
              <ul class="mt-6 grid gap-6 sm:grid-cols-2">
                {readNext.map(p => (
                  <li class="corners glass p-6">
                    <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
                    <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-accent">Dayel Ostraco</p>
                    <h3 class="mt-3 text-lg font-semibold tracking-tight md:text-xl">
                      <a href={`/insights/${p.id}/`} class="transition-colors hover:text-accent">{p.data.title}</a>
                    </h3>
                    <p class="mt-2 leading-relaxed text-text-dim">{p.data.summary}</p>
                    <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.24em] text-text-dim">
                      <time datetime={p.data.date.toISOString()}>{fmtDate(p.data.date)}</time>
                      {p.data.readTime && <span>&nbsp;&middot;&nbsp;{p.data.readTime}</span>}
                    </p>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <p class="mt-14 border-t border-black/10 pt-8">
            <a href="/insights/" class="inline-flex items-center gap-2 font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-text-dim transition-colors hover:text-accent">
              <span aria-hidden="true">&larr;</span>
              Back to Insights
            </a>
          </p>
        </div>
      </section>
    </article>
  </main>

  <Footer />
</Layout>
