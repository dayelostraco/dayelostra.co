---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const all = await getCollection('insights', ({ data }) => import.meta.env.DEV || !data.draft);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// timeZone: 'UTC' — date-only frontmatter is UTC midnight; format in
// UTC so it shows the intended day on west-of-UTC build machines.
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Layout
  title="Insights · Dayel Ostraco"
  description="Field notes on agents, identity, and shipping inside the federal boundary, from 20 years of mission engineering."
  ogImage="/assets/img/og.jpg"
  ogImageAlt="Dayel Ostraco, Insights. Field notes on agents, identity, and shipping inside the federal boundary."
>
  <Navbar home={false} />

  <main id="main-content" tabindex="-1">

    <!-- HERO -->
    <section class="section-dark corners corners-lg relative overflow-hidden px-6 pt-32 pb-16 lg:px-8 lg:pt-40 lg:pb-20">
      <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
      <div class="absolute inset-0 -z-10 dot-grid opacity-40" aria-hidden="true"></div>
      <div class="absolute inset-0 -z-10 grain opacity-25" aria-hidden="true"></div>
      <span class="section-watermark-text" aria-hidden="true" style="top:1rem;right:2rem;" data-watermark="/INSIGHTS"></span>

      <div class="mx-auto max-w-4xl">
        <p class="eyebrow">Insights</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">Field notes from inside the boundary</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-dim md:text-xl">
          Agents, identity, and shipping under federal accreditation. Commentary from 20 years of mission engineering across DoD, DHA, SSA, and CMS.
        </p>
      </div>
    </section>

    <!-- LISTING -->
    <section aria-labelledby="insights-list-heading" class="relative overflow-hidden px-6 py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-4xl">
        <div class="flex items-baseline justify-between gap-6">
          <h2 id="insights-list-heading" class="eyebrow">Latest</h2>
          <a href="/insights/rss.xml" class="font-mono text-xs uppercase tracking-[0.24em] text-text-dim transition-colors hover:text-accent">
            RSS feed &rarr;
          </a>
        </div>

        {posts.length === 0 ? (
          <div class="corners glass mt-10 p-10 text-center">
            <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
            <p class="eyebrow-dim">Empty for now</p>
            <p class="mt-4 text-xl font-semibold tracking-tight md:text-2xl">No insights yet.</p>
            <p class="mx-auto mt-4 max-w-md leading-relaxed text-text-dim">
              Commentary lands here when there is something specific to say. Subscribe via the RSS feed above so the first post finds you.
            </p>
          </div>
        ) : (
          <ul class="mt-10 space-y-8">
            {posts.map(post => (
              <li class="group corners glass glass-hover">
                <span class="cf-tl"></span><span class="cf-tr"></span><span class="cf-bl"></span><span class="cf-br"></span>
                {post.data.heroImage && (
                  <a href={`/insights/${post.id}/`} class="block overflow-hidden">
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.heroImageAlt ?? ''}
                      widths={[400, 800, 1200]}
                      sizes="(min-width: 1024px) 900px, 100vw"
                      class="h-48 w-full object-cover transition duration-500 motion-safe:group-hover:scale-[1.02] sm:h-56"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="p-7 sm:p-8">
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.28em] text-accent">
                      Dayel Ostraco
                    </p>
                    <time datetime={post.data.date.toISOString()} class="font-mono text-[11px] uppercase tracking-[0.24em] text-text-dim">
                      {fmtDate(post.data.date)}
                      {post.data.readTime && <span>&nbsp;&middot;&nbsp;{post.data.readTime}</span>}
                    </time>
                  </div>
                  <h3 class="mt-4 text-xl font-semibold tracking-tight md:text-2xl">
                    <a href={`/insights/${post.id}/`} class="transition-colors hover:text-accent">{post.data.title}</a>
                  </h3>
                  <p class="mt-3 leading-relaxed text-text-dim">{post.data.summary}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <ul class="mt-5 flex flex-wrap gap-2">
                      {post.data.tags.map(tag => (
                        <li class="rounded-full bg-accent/10 px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-accent ring-1 ring-accent/25">
                          {tag}
                        </li>
                      ))}
                    </ul>
                  )}
                  <p class="mt-5">
                    <a href={`/insights/${post.id}/`} class="inline-flex items-center gap-2 font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-accent transition-colors hover:text-accent-deep">
                      Read the post
                      <span aria-hidden="true">&rarr;</span>
                    </a>
                  </p>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
